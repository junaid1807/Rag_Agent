{"docstore/metadata": {"67ca7b9d-7997-4f90-b300-2df808e7d784": {"doc_hash": "e6585e09d92b110ea8e958c644ef5a230c88dc1d4027ca303596bf85cd007236"}, "ae12de66-e926-4f15-b065-0ece2c2ede6c": {"doc_hash": "2ea6ae368e775791a8b15be0be702dda14c9b26a72da3f91da751b30e45dba20"}, "2c048273-fed2-4523-a5b0-1880ce4a1e37": {"doc_hash": "cdce15d6d0c7464aeabc7408cec6438eab8513ab739fdcbe09bb2834a292c5d7"}, "39fc928e-ed8c-4c52-ae42-f3bd1d419c0a": {"doc_hash": "66802e70efeb95d21b1b53c8ddcb3f7a8da9fd0efb10abf84fa93b69b77bd042"}, "0392fe3b-190c-4743-a5b3-fac9ff290090": {"doc_hash": "856d38fc517f2e3aba05c1799186aeb3511d0b1b4b9fc77efa522b98f916b82a"}, "f16d351e-8b1d-44c0-8319-765665750c1f": {"doc_hash": "75126e3e1f00d733387a44ded375f80bc655e290697562abe3ac2c0912ca30c8", "ref_doc_id": "67ca7b9d-7997-4f90-b300-2df808e7d784"}, "1385df34-cbb3-4b7d-8ff5-83b4ae4f986e": {"doc_hash": "3b34536f23d194e65eac2fa1e337cb34ca6507d2b8393029540e4bb9c8151282", "ref_doc_id": "ae12de66-e926-4f15-b065-0ece2c2ede6c"}, "d4af7c19-c2bc-4e4b-92f1-4f42f3c2df3d": {"doc_hash": "c02dc467b1a5d459024d46ca42cbdaab120f7165ccab4cdc75c6c5543ddf46c2", "ref_doc_id": "2c048273-fed2-4523-a5b0-1880ce4a1e37"}, "26dcb5a3-0f72-472b-8cc5-1763b05dd934": {"doc_hash": "65ec44088a2e1b51cc48cd139ba636e30ef87974b57c56f056b5b6abd7007ff7", "ref_doc_id": "39fc928e-ed8c-4c52-ae42-f3bd1d419c0a"}, "e1305809-2588-4773-9b37-a64d9c822437": {"doc_hash": "d19d3df5daf5480c91a7135dff3acc9e553d56777cf273b131f80673df1ef7cb", "ref_doc_id": "0392fe3b-190c-4743-a5b3-fac9ff290090"}}, "docstore/ref_doc_info": {"67ca7b9d-7997-4f90-b300-2df808e7d784": {"node_ids": ["f16d351e-8b1d-44c0-8319-765665750c1f"], "metadata": {}}, "ae12de66-e926-4f15-b065-0ece2c2ede6c": {"node_ids": ["1385df34-cbb3-4b7d-8ff5-83b4ae4f986e"], "metadata": {}}, "2c048273-fed2-4523-a5b0-1880ce4a1e37": {"node_ids": ["d4af7c19-c2bc-4e4b-92f1-4f42f3c2df3d"], "metadata": {}}, "39fc928e-ed8c-4c52-ae42-f3bd1d419c0a": {"node_ids": ["26dcb5a3-0f72-472b-8cc5-1763b05dd934"], "metadata": {}}, "0392fe3b-190c-4743-a5b3-fac9ff290090": {"node_ids": ["e1305809-2588-4773-9b37-a64d9c822437"], "metadata": {}}}, "docstore/data": {"f16d351e-8b1d-44c0-8319-765665750c1f": {"__data__": {"id_": "f16d351e-8b1d-44c0-8319-765665750c1f", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "67ca7b9d-7997-4f90-b300-2df808e7d784", "node_type": "4", "metadata": {}, "hash": "e6585e09d92b110ea8e958c644ef5a230c88dc1d4027ca303596bf85cd007236", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Retrieval-Augmented Generation (RAG) is a technique that combines the strengths of \n    large language models with external knowledge retrieval. In RAG, relevant documents are \n    fetched from a vector store based on the user query, and then passed as context to the LLM \n    to generate a grounded, accurate response. This reduces hallucinations and keeps information \n    up-to-date without expensive retraining.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 415, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "1385df34-cbb3-4b7d-8ff5-83b4ae4f986e": {"__data__": {"id_": "1385df34-cbb3-4b7d-8ff5-83b4ae4f986e", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ae12de66-e926-4f15-b065-0ece2c2ede6c", "node_type": "4", "metadata": {}, "hash": "2ea6ae368e775791a8b15be0be702dda14c9b26a72da3f91da751b30e45dba20", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "LlamaIndex (formerly GPT Index) is a data framework for building LLM-powered applications. \n    It provides connectors to ingest data from various sources (PDFs, APIs, databases), \n    efficient indexing using vector stores like FAISS or Pinecone, and query engines with \n    sub-question decomposition, re-ranking, and hybrid search. LlamaIndex integrates seamlessly \n    with LangChain for agentic workflows.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 410, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "d4af7c19-c2bc-4e4b-92f1-4f42f3c2df3d": {"__data__": {"id_": "d4af7c19-c2bc-4e4b-92f1-4f42f3c2df3d", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "2c048273-fed2-4523-a5b0-1880ce4a1e37", "node_type": "4", "metadata": {}, "hash": "cdce15d6d0c7464aeabc7408cec6438eab8513ab739fdcbe09bb2834a292c5d7", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "LangChain is a framework for developing applications powered by language models. \n    It enables building agents that can reason step-by-step using the ReAct (Reasoning + Acting) \n    paradigm. Agents decide which tools to call \u2014 such as search, calculators, or databases \u2014 \n    based on the user's goal, execute actions, observe results, and iterate until a final \n    answer is reached.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 388, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "26dcb5a3-0f72-472b-8cc5-1763b05dd934": {"__data__": {"id_": "26dcb5a3-0f72-472b-8cc5-1763b05dd934", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "39fc928e-ed8c-4c52-ae42-f3bd1d419c0a", "node_type": "4", "metadata": {}, "hash": "66802e70efeb95d21b1b53c8ddcb3f7a8da9fd0efb10abf84fa93b69b77bd042", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "FAISS (Facebook AI Similarity Search) is a library for efficient similarity search \n    and clustering of dense vectors. It supports billion-scale vector search and provides \n    multiple index types: Flat (exact), IVF (approximate), and HNSW (graph-based). \n    FAISS is highly optimized for GPU and CPU and is widely used as the backbone \n    for vector databases in RAG systems.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 381, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e1305809-2588-4773-9b37-a64d9c822437": {"__data__": {"id_": "e1305809-2588-4773-9b37-a64d9c822437", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "0392fe3b-190c-4743-a5b3-fac9ff290090", "node_type": "4", "metadata": {}, "hash": "856d38fc517f2e3aba05c1799186aeb3511d0b1b4b9fc77efa522b98f916b82a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Agentic AI refers to systems where an LLM autonomously plans and executes multi-step \n    tasks by calling tools, APIs, or sub-agents. Unlike a single-turn chatbot, an agentic \n    system maintains state across steps, backtracks on failure, and selects the best \n    strategy from multiple options. Key components include a planner, a tool executor, \n    memory, and an evaluator.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 380, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}}